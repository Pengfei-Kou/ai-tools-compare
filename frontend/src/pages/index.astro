---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Find the Best AI Model for Your Project">
  <section class="hero">
    <h1>Compare AI Models,<br /><span>Make Smarter Choices</span></h1>
    <p class="subtitle">
      Real-time pricing, performance benchmarks, and honest reviews of GPT-5, Claude 4.6, Gemini 3, DeepSeek V4, and more.
    </p>
    <div class="cta-group">
      <a href="/pricing" class="btn btn-primary">Compare Pricing</a>
      <a href="/blog" class="btn btn-secondary">Read Reviews</a>
    </div>
  </section>

  <section class="features">
    <div class="feature-card">
      <h3>Up-to-date Pricing</h3>
      <p>Token costs for all major AI APIs, updated regularly with historical trends.</p>
    </div>
    <div class="feature-card">
      <h3>Side-by-side Comparison</h3>
      <p>Compare models by price, speed, context window, and benchmark scores.</p>
    </div>
    <div class="feature-card">
      <h3>Honest Reviews</h3>
      <p>Real-world testing and analysis to help you pick the right model.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  h1 {
    font-size: 3rem;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  h1 span {
    color: var(--color-primary);
  }

  .subtitle {
    color: var(--color-text-muted);
    font-size: 1.2rem;
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn {
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg);
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    color: var(--color-bg);
  }

  .btn-secondary {
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-secondary:hover {
    border-color: var(--color-primary);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    padding: 2rem 0 4rem;
  }

  .feature-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
  }

  .feature-card h3 {
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .feature-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
</style>