---
import BaseLayout from '../layouts/BaseLayout.astro';
import ModelsTable from '../components/ModelsTable';
---

<BaseLayout title="Compare AI Models" description="Side-by-side comparison of all major AI models with pricing, context window, and performance.">
  <section class="page-header">
    <h1>AI Models Comparison</h1>
    <p>Compare pricing and capabilities across major providers. Click any column to sort.</p>
  </section>

  <ModelsTable client:load />
</BaseLayout>

<style>
  .page-header {
    padding: 2rem 0 1rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--color-text-muted);
  }
</style>
